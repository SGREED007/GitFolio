# ─── GitHub App Credentials ───
# Create a GitHub App at https://github.com/settings/apps
AUTH_GITHUB_ID=your_github_app_client_id
AUTH_GITHUB_SECRET=your_github_app_client_secret

# ─── Auth.js Secret ───
# Generate a random secret: openssl rand -hex 32
AUTH_SECRET=your_authjs_secret_min_32_chars

# ─── Supabase ───
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── App Base URL (REQUIRED — Auth.js uses this to build callback URLs) ───
# Local dev:
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Production (set these in Vercel Dashboard → Environment Variables):
# AUTH_URL=https://gitfoliopro.vercel.app
# NEXTAUTH_URL=https://gitfoliopro.vercel.app
